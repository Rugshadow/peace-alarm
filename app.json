{
  "expo": {
    "name": "PeaceAlarm",
    "slug": "peace-alarm",
    "version": "1.0.0",
    "scheme": "peace-alarm",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.peacealarm.app",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.peacealarm.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#DFFF00"
      }
    },
    "plugins": [
      "expo-router",
      "expo-av",
      "expo-web-browser"
    ]
  }
}
